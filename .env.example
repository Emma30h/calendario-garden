# Supabase project base URL (example: https://xyzcompany.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Optional server-only alias for the same URL.
# If empty, the API will use NEXT_PUBLIC_SUPABASE_URL.
SUPABASE_URL=

# Server-only key used by Next.js API routes.
# Never expose this key in the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Session signing secret (server-only, min 32 chars).
AUTH_SESSION_SECRET=

# Optional extra secret used to hash OTP codes.
AUTH_OTP_PEPPER=

# Optional local fallback to show OTP in UI when Brevo is not configured.
# Keep empty/false to force real e-mail delivery and show config errors.
AUTH_ALLOW_DEV_OTP_FALLBACK=

# Brevo API key for transactional e-mail sends (server-side only).
# Create it in Brevo -> SMTP & API -> API keys.
BREVO_API_KEY=

# Sender used for outbound e-mails from Brevo.
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Calendario Garden

# Secret required by cron endpoint /api/notifications/run-daily.
# Send as Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Local business timezone used to decide "today" for daily notifications.
APP_TIMEZONE=America/Argentina/Buenos_Aires

# Public base URL used in e-mail templates for logo/assets.
# Example: https://tu-dominio.com
APP_BASE_URL=

# Optional full logo URL for e-mail header.
# If empty, API will use APP_BASE_URL + /logo-ojos-en-alerta-blanco.png
APP_LOGO_URL=

# Optional UI mode for /anual/email.
# Set to "test" to hide daily-run controls and show only test send tools.
NEXT_PUBLIC_EMAIL_PANEL_MODE=
